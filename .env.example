# Seed keys into SQLite on startup (optional after first run).
# Prefer storing keys via POST /videos/keys so you never restart to switch.
AGNES_API_KEY_1=
AGNES_API_KEY_2=
AGNES_API_KEY_3=
# Alternative: comma-separated list
# AGNES_API_KEYS=key1,key2,key3

AGNES_API_BASE_URL=https://apihub.agnes-ai.com
AGNES_MODEL=agnes-video-v2.0

DATABASE_PATH=./data/vocabulary-videos.sqlite
DATABASE_SYNCHRONIZE=true
SOURCE_ROOT=./src/static
VIDEO_OUTPUT_ROOT=./videos
LOG_DIRECTORY=./logs
LOG_LEVEL=info
LOG_RETENTION=14d

# Soft estimate only (for logging/stats). Real stop = HTTP 429 quota on all keys.
DAILY_VIDEO_SECONDS=500
VIDEO_CLIP_SECONDS=5
VIDEO_POLL_INTERVAL_MS=60000
VIDEO_MAX_ATTEMPTS=3
VIDEO_TIMEZONE=Asia/Shanghai
WORKER_AUTO_START=true

VIDEO_HEIGHT=768
VIDEO_WIDTH=1152
VIDEO_NUM_FRAMES=121
VIDEO_FRAME_RATE=24
AGNES_REQUEST_TIMEOUT_MS=30000
VIDEO_DOWNLOAD_TIMEOUT_MS=120000

# Optional when ffmpeg is not available on PATH.
FFMPEG_PATH=ffmpeg
